    "preview": "astro preview",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 astro check"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/lilex": "^5.2.1",
    "@fontsource-variable/stack-sans-text": "^5.2.1",
    "@kernelui-lib/elements": "workspace:*",
    "@kernelui-lib/react": "workspace:*",
    "@kernelui-lib/styles": "workspace:*",
    "astro": "^7.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "node-html-parser": "^8.0.4",
    "typescript": "^5.7.3"
  }
