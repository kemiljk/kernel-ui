---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemePlayground from "../components/ThemePlayground";
import HeroCtas from "../components/HeroCtas";
import OpenSourceCallout from "../components/OpenSourceCallout";
import CodeBlock from "../components/CodeBlock.astro";
import KernelMark from "../components/KernelMark.astro";
import { components } from "../data/components";
import { GITHUB_URL } from "../lib/site";
import BookDemoCard from "../components/showcase/BookDemoCard";
import StatusRow from "../components/showcase/StatusRow";
import EditorSettings from "../components/showcase/EditorSettings";
import DocsNav from "../components/showcase/DocsNav";
import CodePreviewToggle from "../components/showcase/CodePreviewToggle";
import CommandShortcuts from "../components/showcase/CommandShortcuts";
import AvatarGroup from "../components/showcase/AvatarGroup";
import AccountMenu from "../components/showcase/AccountMenu";
import ButtonVariants from "../components/showcase/ButtonVariants";
import InstallCard from "../components/showcase/InstallCard";
import RepoCard from "../components/showcase/RepoCard";
import PlatformCards from "../components/showcase/PlatformCards";
import UpdateBanner from "../components/showcase/UpdateBanner";
import NotificationToggle from "../components/showcase/NotificationToggle";
import UnsavedChangesCard from "../components/showcase/UnsavedChangesCard";

const available = components.filter((c) => c.status === "available").length;
const planned = components.length - available;

const cascadeSnippet = `--kernel-hue-accent: 70;       /* → every accent shade re-hues */
--kernel-radius-base: 1.25rem; /* → every corner re-rounds */
--kernel-space-unit: 0.25rem;  /* → every gap and padding rescales */`;

const kernelSnippet = `<button
  type="button"
  onClick={save}
>
  Save changes
</button>`;

const divSoupSnippet = `<div
  role="button"
  tabIndex={0}
  aria-disabled="false"
  onClick={save}
  onKeyDown={(e) => {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      save(e);
    }
  }}
>
  Save changes
</div>`;

const reactPlatformSnippet = `import { Button } from "@kernelui-lib/react";

<Button variant="primary">Save changes</Button>`;

const elementsPlatformSnippet = `<script type="module">
  import "@kernelui-lib/elements";
</script>

<kernel-button variant="primary">Save changes</kernel-button>`;

const headlessPlatformSnippet = `import { Button } from "@kernelui-lib/react";
// No "@kernelui-lib/react/styles.css" import anywhere —
// <Button> is still a real <button>, just unstyled.`;

const CONTRIBUTING_URL = `${GITHUB_URL}/blob/master/CONTRIBUTING.md`;
---

<BaseLayout title="Home" description="A component library built on real semantic HTML — React and Web Components, one shared token layer.">
  <div class="home">
  <section class="hero">
    <KernelMark class="hero-mark" />
    <div class="hero-copy">
      <h1>The kernel of the web, componentised.</h1>
      <p>
        A component library built on real semantic HTML instead of div
        soup.
      </p>
      <div class="hero-ctas">
        <HeroCtas />
      </div>
    </div>
  </section>

  <section class="feature-section" aria-labelledby="showcase-heading">
    <p class="section-eyebrow">Showcase</p>
    <h2 id="showcase-heading">Real components, composed into real screens</h2>
    <p class="principles-intro">
      A scheduling card. A docs nav. An install panel. Each one is the
      real library at work, not a screenshot.
    </p>
    <div class="showcase-bleed">
      <div class="showcase-columns">
      <div class="showcase-card">
        <h3>One value, one cascade</h3>
        <p>
          Every colour, radius, and duration is a CSS custom property.
          Change one token and every component updates, live, everywhere
          it's used — try it further down the page.
        </p>
        <CodeBlock code={cascadeSnippet} lang="css" />
      </div>
      <BookDemoCard client:visible />
      <StatusRow client:visible />
      <EditorSettings client:visible />
      <DocsNav client:visible />
      <CodePreviewToggle client:visible />
      <CommandShortcuts client:visible />
      <AvatarGroup client:visible />
      <AccountMenu client:visible />
      <ButtonVariants client:visible />
      <InstallCard client:visible />
      <RepoCard client:visible />
      <PlatformCards client:visible />
      <UpdateBanner client:visible />
      <NotificationToggle client:visible />
      <UnsavedChangesCard client:visible />
      </div>
    </div>
  </section>

  <section class="principles" aria-labelledby="principles-heading">
    <p class="section-eyebrow">Principles</p>
    <h2 id="principles-heading">How it's built</h2>
    <p class="principles-intro">
      Four decisions that shape every component, not just the ones on this page.
    </p>
    <dl class="principles-list">
      <div class="principle">
        <dt>Composition</dt>
        <dd>
          An explicit <code>render</code> prop, not <code>asChild</code> magic.
          What actually renders is always visible at the call site.
        </dd>
      </div>
      <div class="principle">
        <dt>State</dt>
        <dd>
          Real pseudo-classes — <code>:checked</code>, <code>:disabled</code>,
          <code>:user-invalid</code> — wherever the browser already gives you
          one. <code>data-*</code> everywhere else.
        </dd>
      </div>
      <div class="principle">
        <dt>Distribution</dt>
        <dd>
          A versioned, tree-shakeable npm package, not a copy-paste registry.
          Import what you use.
        </dd>
      </div>
      <div class="principle">
        <dt>Naming</dt>
        <dd>
          The actual kernel of the web: the elements and behaviour
          browsers already ship.
        </dd>
      </div>
    </dl>
  </section>

  <section class="comparison" aria-labelledby="comparison-heading">
    <p class="section-eyebrow">Comparison</p>
    <h2 id="comparison-heading">What a real element buys you</h2>
    <p class="comparison-intro">
      Same button, same look. One gets focus, keyboard activation, and
      disabled state from the browser for free. The other has to catch up
      by hand, and still won't get form submission or <code>:focus-visible</code> right
      without more code.
    </p>
    <div class="comparison-grid">
      <div class="comparison-panel">
        <p class="comparison-label">Kernel</p>
        <CodeBlock code={kernelSnippet} lang="tsx" />
      </div>
      <div class="comparison-panel">
        <p class="comparison-label">Div soup</p>
        <CodeBlock code={divSoupSnippet} lang="tsx" />
      </div>
    </div>
  </section>

  <section class="platforms" aria-labelledby="platforms-heading">
    <p class="section-eyebrow">Platforms</p>
    <h2 id="platforms-heading">Everywhere you already build</h2>
    <p class="comparison-intro">
      Three ways in. <code>@kernelui-lib/react</code> is the flagship.{" "}
      <code>@kernelui-lib/elements</code> is the same design system as native
      Custom Elements — Vue, Svelte, Astro, or plain HTML, no wrapper
      required. Or skip the stylesheet on either one and get real,
      fully-functional semantic elements with none of Kernel's own look —
      just the bones, themed however you want.
    </p>
    <div class="comparison-grid platforms-grid">
      <div class="comparison-panel">
        <p class="comparison-label">React</p>
        <CodeBlock code={reactPlatformSnippet} lang="tsx" />
      </div>
      <div class="comparison-panel">
        <p class="comparison-label">Anywhere else</p>
        <CodeBlock code={elementsPlatformSnippet} lang="html" />
      </div>
      <div class="comparison-panel">
        <p class="comparison-label">Unstyled</p>
        <CodeBlock code={headlessPlatformSnippet} lang="tsx" />
      </div>
    </div>
    <p class="platforms-cta"><a href="/platforms/">More on platforms &amp; headless usage →</a></p>
  </section>

  <section class="playground-section" aria-labelledby="playground-heading">
    <p class="section-eyebrow">Playground</p>
    <h2 id="playground-heading">Try the cascade</h2>
    <ThemePlayground client:load />
  </section>

  <section class="closing">
    <p class="section-eyebrow">Get started</p>
    <h2>Built on the parts of the web that already work.</h2>
    <p class="closing-intro">
      Kernel is MIT-licensed and developed on GitHub. Contributions to
      docs, accessibility, and component parity are welcome.
      {available} components are ready today{planned > 0 ? `, with ${planned} more on the way.` : ". The full set is live."}
    </p>
    <OpenSourceCallout client:visible />
    <p class="closing-links">
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">View on GitHub</a>
      <span aria-hidden="true"> · </span>
      <a href={CONTRIBUTING_URL} target="_blank" rel="noopener noreferrer">Contributing guide</a>
    </p>
    <div class="hero-ctas">
      <HeroCtas />
    </div>
  </section>
  </div>
</BaseLayout>
