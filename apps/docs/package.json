{
  "name": "docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/fetch-github-stars.mjs && NODE_OPTIONS=--max-old-space-size=8192 astro check && astro build && node scripts/generate-markdown.mjs",
