---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import ExampleGrid from "../../components/ExampleGrid.astro";
import Example from "../../components/Example.astro";
import ButtonDemo from "../../components/demos/ButtonDemo";
import ButtonPlayground from "../../components/demos/ButtonPlayground";
import ButtonIconsExample from "../../components/demos/ButtonIconsExample";
import ButtonAsLinkExample from "../../components/demos/ButtonAsLinkExample";
import { Button } from "@kernelui-lib/react";

const variantsSnippet = `<Button variant="primary">Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="danger">Danger</Button>`;

const iconsSnippet = `<Button variant="secondary" iconStart={<MagnifyingGlassIcon />}>
  Search
</Button>
<Button variant="primary" iconEnd={<CheckIcon />}>
  Mark as done
</Button>
<Button variant="ghost" aria-label="Copy" iconStart={<CopyIcon />} />`;

const disabledSnippet = `<Button disabled>Disabled</Button>`;

const asLinkSnippet = `// render swaps the underlying element — the action here
// navigates, so it should be a real <a>, not a <button>.
<Button render={<a href="/pricing/">See pricing</a>}>
  See pricing
</Button>`;
---

<BaseLayout title="Button" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Button</h1>
    <p>
      Renders a real <code>&lt;button type="button"&gt;</code> by default. Use{" "}
      <code>render</code> when the action navigates rather than does
      something in place, so it renders as an <code>&lt;a&gt;</code> instead.
    </p>

    <div class="docs-example">
      <ButtonDemo client:load />
    </div>

    <h2>Examples</h2>
    <ExampleGrid>
      <Example
        title="Variants"
        description="Four visual weights, from the primary action to a destructive one."
        code={variantsSnippet}
      >
        <Button variant="primary">Primary</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="danger">Danger</Button>
      </Example>
      <Example
        title="With icons"
        description="iconStart/iconEnd, or an icon alone with aria-label for an icon-only button."
        code={iconsSnippet}
      >
        <ButtonIconsExample client:load />
      </Example>

      <Example title="Disabled" description="Native disabled state — no aria-disabled workaround needed." code={disabledSnippet}>
        <Button disabled>Disabled</Button>
      </Example>

      <Example
        title="Rendered as a link"
        description="render swaps in a real <a> for actions that navigate instead of acting in place."
        code={asLinkSnippet}
      >
        <ButtonAsLinkExample client:load />
      </Example>
    </ExampleGrid>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the button — and the code — update live.</p>
    <ButtonPlayground client:load />

    
    <h2>Props</h2>
    <div class="docs-table-scroll"><table class="docs-table">
      <caption>Only the props specific to Button. Every native button attribute (onClick, form, name…) also works.</caption>
      <thead>
        <tr><th scope="col">Prop</th><th scope="col">Type</th><th scope="col">Default</th></tr>
      </thead>
      <tbody>
        <tr><td><code>variant</code></td><td>"primary" | "secondary" | "ghost" | "danger"</td><td>"secondary"</td></tr>
        <tr><td><code>size</code></td><td>"sm" | "md" | "lg"</td><td>"md"</td></tr>
        <tr><td><code>loading</code></td><td>boolean</td><td>false</td></tr>
        <tr><td><code>iconStart</code> / <code>iconEnd</code></td><td>ReactNode</td><td>—</td></tr>
        <tr><td><code>render</code></td><td>ReactElement | (props, state) =&gt; ReactElement</td><td>—</td></tr>
      </tbody>
    </table></div>

    <h2>Accessibility</h2>
    <ul>
      <li>Space and Enter activate it, focus and disabled state are native.</li>
      <li>
        When rendered via <code>render</code> as something other than a
        button (an <code>&lt;a&gt;</code>, say), <code>disabled</code> becomes{" "}
        <code>aria-disabled</code> plus a blocked click handler, since
        non-form elements have no native disabled behaviour.
      </li>
      <li><code>loading</code> sets <code>aria-busy</code> without changing the button's width.</li>
    </ul>
  </div>
</BaseLayout>
