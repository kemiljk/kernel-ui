{
  "name": "@kernelui-lib/elements",
  "version": "1.0.0",
  "description": "Kernel's components as native Custom Elements — framework-agnostic, light DOM, zero runtime dependencies.",
  "license": "MIT",
  "author": "Karl Koch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kemiljk/kernel-ui.git",
    "directory": "packages/elements"
  },
  "homepage": "https://www.kernelui.com",
  "bugs": "https://github.com/kemiljk/kernel-ui/issues",
  "keywords": [
    "web-components",
    "custom-elements",
    "components",
    "accessibility",
    "design-system"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/kernel.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/kernel.css"
  },
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": true,
  "dependencies": {
    "@kernelui-lib/styles": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^4.4.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  }
}
