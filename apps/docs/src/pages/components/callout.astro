---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import CalloutDemo from "../../components/demos/CalloutDemo";
import CalloutPlayground from "../../components/demos/CalloutPlayground";
---

<BaseLayout title="Callout" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Callout</h1>
    <p>
      There's no <code>&lt;callout&gt;</code> element, ARIA live-region roles
      are the correct tool for exactly this gap. <code>danger</code>/
      <code>warning</code> interrupt (<code>role="alert"</code>, assertive);
      <code>info</code>/<code>success</code> wait their turn
      (<code>role="status"</code>, polite).
    </p>

    <div class="docs-example" style="flex-direction: column; align-items: stretch;">
      <CalloutDemo client:load />
    </div>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the component — and the code — update live.</p>
    <CalloutPlayground client:load />

    <h2>Props</h2>
    <div class="docs-table-scroll"><table class="docs-table">
      <caption>Props for Callout.</caption>
      <thead><tr><th scope="col">Prop</th><th scope="col">Type</th><th scope="col">Default</th></tr></thead>
      <tbody>
        <tr><td><code>variant</code></td><td>"info" | "success" | "warning" | "danger"</td><td>"info"</td></tr>
        <tr><td><code>title</code></td><td>ReactNode</td><td>—</td></tr>
      </tbody>
    </table></div>
  </div>
</BaseLayout>
