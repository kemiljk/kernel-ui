---
// Headings are the source of truth: this reads `.docs-prose h2/h3` from
// the DOM at runtime rather than requiring each of the 28 component
// pages to hand-maintain a separate list that could drift out of sync.
// Plain script, no framework — a sidebar this small doesn't need an
// island.
---

<nav class="toc" aria-label="On this page">
  <p class="toc-label">On this page</p>
  <ul class="toc-list"></ul>
</nav>

<script>
  function slugify(text: string) {
    return text
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)/g, "");
  }

  function buildToc() {
    const nav = document.querySelector<HTMLElement>(".toc");
    const list = document.querySelector<HTMLUListElement>(".toc-list");
    // Direct children only: a live component demo embedded in the page
    // (a Card title, a Dialog's own heading) can itself contain an
    // h2/h3 several levels deep inside `.docs-example` — that's the
    // component's own semantic structure, not page structure, and a
    // descendant selector would wrongly pull it into the TOC.
    const headings = document.querySelectorAll<HTMLHeadingElement>(
      ".docs-prose > h2, .docs-prose > h3",
    );

    if (!nav || !list) return;
    if (headings.length === 0) {
      nav.remove();
      return;
    }

    const usedIds = new Set<string>();
    const links: HTMLAnchorElement[] = [];

    headings.forEach((heading) => {
      let id = heading.id || slugify(heading.textContent ?? "");
      while (usedIds.has(id)) id += "-2";
      usedIds.add(id);
      heading.id = id;

      const item = document.createElement("li");
      item.className =
        heading.tagName === "H3" ? "toc-item toc-item-sub" : "toc-item";

      const link = document.createElement("a");
      link.href = `#${id}`;
      link.textContent = heading.textContent;
      item.appendChild(link);
      list.appendChild(item);
      links.push(link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const link = list.querySelector<HTMLAnchorElement>(
            `a[href="#${entry.target.id}"]`,
          );
          if (link && entry.isIntersecting) {
            for (const l of links) l.removeAttribute("aria-current");
            link.setAttribute("aria-current", "true");
          }
        }
      },
      { rootMargin: "0px 0px -70% 0px" },
    );
    headings.forEach((heading) => observer.observe(heading));
  }

  buildToc();
</script>
