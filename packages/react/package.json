{
  "name": "@kernelui-lib/react",
  "version": "1.0.0",
  "description": "Accessible React components built on real semantic HTML, not div soup.",
  "license": "MIT",
  "author": "Karl Koch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kemiljk/kernel-ui.git",
    "directory": "packages/react"
  },
  "homepage": "https://www.kernelui.com",
  "bugs": "https://github.com/kemiljk/kernel-ui/issues",
  "keywords": [
    "react",
    "components",
    "accessibility",
    "design-system",
    "semantic-html"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/kernel.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/kernel.css"
  },
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@kernelui-lib/styles": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.0.4"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "prepublishOnly": "npm run build"
  }
}
