  </a>
  <Nav
    aria-label="Primary"
    data-orientation="horizontal"
    className="site-nav-desktop"
    style={{ flex: 1, marginInline: "2rem" }}
  >
    {
      items.map((item) => (
        <NavLink
          href={item.href}
          aria-current={path === item.href ? "page" : undefined}
        >
          {item.label}
        </NavLink>
      ))
    }
  </Nav>
  <div class="site-header-toggle-desktop">
    <CommandPalette client:load />
    <ThemeMenu client:load />
    <ThemeToggle client:load />
  </div>
  <MobileHeaderNav client:load items={items} currentPath={path} />
</Header>
