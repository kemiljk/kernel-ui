---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/stack-sans-text";
import "@fontsource-variable/lilex";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import MobileNav from "../components/MobileNav";
import DocsSidebarNav from "../components/DocsSidebarNav.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { components } from "../data/components";
import { SITE_URL, SITE_NAME, SITE_DEFAULT_TITLE, SITE_DEFAULT_DESCRIPTION } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  withSidebar?: boolean;
}

const {
  title,
  description: descriptionProp,
  withSidebar = false,
} = Astro.props;

const slugMatch = Astro.url.pathname.match(/^\/components\/([^/]+)\/$/);
const componentEntry = slugMatch
  ? components.find((c) => c.slug === slugMatch[1])
  : undefined;

const description =
  descriptionProp ??
  (componentEntry
    ? `${componentEntry.summary} Built on ${componentEntry.element}.`
    : SITE_DEFAULT_DESCRIPTION);

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = new URL("/og.png", SITE_URL).href;
const pageTitle =
  Astro.url.pathname === "/" ? SITE_DEFAULT_TITLE : `${title} — ${SITE_NAME}`;
---

<!doctype html>
<html lang="en" data-kernel-accent="amber">
  <head>
    <meta charset="utf-8" />
    <!--
      No-FOUC theme init: must run synchronously, before first paint,
      so it can't `import` src/lib/theme.ts (a module import is async
      relative to inline script execution). Keep these storage keys in
      sync with STORAGE_KEYS in that file by hand.

      Also re-run on every `astro:page-load`, not just once: ClientRouter
      swaps in the new page's server-rendered `<html>` attributes on
      every soft navigation, which wipes whatever this same script (or
      ThemeControls) had applied to the *previous* page's `<html>`
      element — accent, radius, and colour scheme would silently reset
      to their static defaults the moment you clicked any internal
      link, even though the values were still sitting in localStorage.
      Only actually noticeable for radius/accent since colour scheme
      also happens to be the initial-load default in light mode, but
      all three share the same bug for the same reason.
    -->
    <script is:inline>
      function kernelApplyStoredTheme() {
        try {
          var accent = localStorage.getItem("kernel:accent");
          if (accent) document.documentElement.setAttribute("data-kernel-accent", accent);
          var radius = localStorage.getItem("kernel:radius");
          if (radius) document.documentElement.style.setProperty("--kernel-radius-base", radius);
          var radiusControl = localStorage.getItem("kernel:radius-control");
          if (radiusControl) {
            // An explicit choice, either "Round" re-applying its pill
            // pairing, or a stale value from before this pairing
            // existed — either way, honour it.
            document.documentElement.style.setProperty("--kernel-radius-control", radiusControl);
          } else if (!radius) {
            // No stored radius preference at all: a fresh visitor, who
            // should see this site's actual default look (pill
            // controls, the same "Round" pairing) — applied here in JS
            // rather than as an unconditional stylesheet rule, which is
            // exactly what silently defeated Sharp/Soft before (see the
            // comment on --kernel-radius-base in global.css).
            document.documentElement.style.setProperty("--kernel-radius-control", "var(--kernel-radius-full)");
          } else {
            // Sharp or Soft explicitly selected: no override, let
            // --kernel-radius-control fall back to its own
            // packages/styles default (derived from --kernel-radius-base,
            // like every other radius tier).
            document.documentElement.style.removeProperty("--kernel-radius-control");
          }
          // "Sharp" additionally overrides these two directly (see the
          // `container`/`sheet` comment on RadiusOption in theme.ts) —
          // without reapplying them here too, a hard reload while Sharp
          // is active would keep --kernel-radius-base at 0 but let
          // --kernel-radius-container/-sheet fall back to their normal
          // formula, silently un-sharpening every Card/Dialog until the
          // user re-clicked the Sharp swatch.
          var radiusContainer = localStorage.getItem("kernel:radius-container");
          if (radiusContainer) {
            document.documentElement.style.setProperty("--kernel-radius-container", radiusContainer);
          } else {
            document.documentElement.style.removeProperty("--kernel-radius-container");
          }
          var radiusSheet = localStorage.getItem("kernel:radius-sheet");
          if (radiusSheet) {
            document.documentElement.style.setProperty("--kernel-radius-sheet", radiusSheet);
          } else {
            document.documentElement.style.removeProperty("--kernel-radius-sheet");
          }
          var scheme = localStorage.getItem("kernel:color-scheme");
          if (scheme === "light" || scheme === "dark") {
            document.documentElement.setAttribute("data-theme", scheme);
          }
        } catch (error) {
          // Storage can throw (private browsing, disabled storage) —
          // the site still works, just without a remembered theme.
        }
      }
      kernelApplyStoredTheme();
      document.addEventListener("astro:after-swap", kernelApplyStoredTheme);

      // The homepage hero's entrance (global.css `.hero`) uses
      // @starting-style, which only fires on a genuine first paint — it
      // never replays on a ClientRouter soft-navigation swap, so
      // navigating home → elsewhere → back to home left the hero just
      // sitting at its resting state with no animation. `astro:after-swap`
      // fires synchronously right as the new page's DOM lands, before
      // it's painted, so setting the same "entering" state here and
      // clearing it a frame later replays the identical transition.
      function kernelReplayHeroEntrance() {
        var hero = document.querySelector(".hero");
        if (!hero) return;
        hero.setAttribute("data-enter", "");
        // Force a layout flush between the two writes below — without
        // this, both attribute changes can coalesce into a single
        // style recalculation and the browser never actually commits
        // the "entering" frame the transition needs to animate from.
        void hero.offsetWidth;
        requestAnimationFrame(function () {
          hero.removeAttribute("data-enter");
        });
      }
      document.addEventListener("astro:after-swap", kernelReplayHeroEntrance);
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="color-scheme" content="light dark" />
    <!-- Same mark as SiteHeader's logo, but with a fixed amber fill rather
         than `var(--kernel-color-accent)`: a favicon loads standalone, with
         no page CSS context, so a theme-reactive colour would just never
         resolve and fall back to nothing. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <!--
      The sidebar below is transition:persist'd across navigations —
      the whole reason ClientRouter is here at all is so switching
      component pages doesn't reset its scroll position. Two gaps that
      leaves, both handled here:

      1. A persisted node keeps its OLD server-rendered content, so
         its baked-in aria-current goes stale after the first soft
         nav. Recomputed by hand on every astro:page-load (fires on
         first load and after every soft nav).
      2. `transition:persist` keeps the same DOM node, but Astro's
         swap still detaches and reappends it as part of the morph —
         and detaching a scrollable element from the DOM resets its
         scrollTop even when it's the same node, so persistence alone
         doesn't actually keep the scroll position. Saved on
         astro:before-swap (the last moment before the old DOM goes
         away) and restored on astro:page-load.
    -->
    <script is:inline>
      var savedSidebarScroll = 0;
      document.addEventListener("astro:before-swap", function () {
        var sidebar = document.querySelector(".docs-sidebar-slot");
        if (sidebar) savedSidebarScroll = sidebar.scrollTop;
      });
      document.addEventListener("astro:page-load", function () {
        var sidebar = document.querySelector(".docs-sidebar-slot");
        if (sidebar) sidebar.scrollTop = savedSidebarScroll;

        var path = location.pathname;
        document.querySelectorAll(".docs-sidebar-slot a[href]").forEach(function (a) {
          if (a.getAttribute("href") === path) {
            a.setAttribute("aria-current", "page");
          } else {
            a.removeAttribute("aria-current");
          }
        });
      });
    </script>
    <!--
      One markdown mirror per component page (generated post-build by
      scripts/generate-markdown.mjs from the same .docs-prose this page
      renders), plus a small copyable-URL chip so a reader can hand the
      link straight to an LLM. Injected here rather than by hand on all
      39 pages: every component page already shares this exact
      `/components/<slug>/` URL shape, so the slug — and therefore
      whether the chip belongs on the page at all — can be derived from
      `location.pathname` alone. Runs on `astro:page-load` (fires on
      first load and every soft nav) rather than once at parse time,
      since ClientRouter swaps `<main>`'s content without a full reload.
    -->
    <script is:inline>
      document.addEventListener("astro:page-load", function () {
        var existingChip = document.querySelector(".docs-markdown-chip");
        if (existingChip) existingChip.remove();

        var match = location.pathname.match(/^\/components\/([^/]+)\/$/);
        if (!match) return;

        var h1 = document.querySelector(".docs-prose h1");
        if (!h1) return;

        var slug = match[1];
        var url = location.origin + "/components/" + slug + ".md";

        var chip = document.createElement("div");
        chip.className = "docs-markdown-chip";
        chip.innerHTML =
          '<span class="docs-markdown-chip-text">/components/' + slug + '.md</span>' +
          '<button type="button" class="docs-markdown-chip-copy" aria-label="Copy markdown URL">' +
          '<svg class="docs-markdown-chip-icon-copy" aria-hidden="true" viewBox="0 0 15 15" width="14" height="14" fill="currentColor" fill-rule="evenodd"><path d="M1 9.5A1.5 1.5 0 0 0 2.5 11H4v-1H2.5a.5.5 0 0 1-.5-.5v-7a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 .5.5V4H5.5A1.5 1.5 0 0 0 4 5.5v7A1.5 1.5 0 0 0 5.5 14h7a1.5 1.5 0 0 0 1.5-1.5v-7A1.5 1.5 0 0 0 12.5 4H11V2.5A1.5 1.5 0 0 0 9.5 1h-7A1.5 1.5 0 0 0 1 2.5v7Zm4-4a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-7a.5.5 0 0 1-.5-.5v-7Z"></path></svg>' +
          '<svg class="docs-markdown-chip-icon-check" aria-hidden="true" viewBox="0 0 15 15" width="14" height="14" fill="currentColor" fill-rule="evenodd"><path d="M11.467 3.727c.289.189.37.576.181.865l-4.25 6.5a.625.625 0 0 1-.944.12l-2.75-2.5a.625.625 0 0 1 .841-.925l2.208 2.007 3.849-5.886a.625.625 0 0 1 .865-.181Z"></path></svg>' +
          "</button>";
        h1.insertAdjacentElement("afterend", chip);

        var button = chip.querySelector("button");
        button.addEventListener("click", function () {
          navigator.clipboard.writeText(url).then(function () {
            button.setAttribute("data-copied", "true");
            button.setAttribute("aria-label", "Copied");
            setTimeout(function () {
              button.removeAttribute("data-copied");
              button.setAttribute("aria-label", "Copy markdown URL");
            }, 1500);
          });
        });
      });
    </script>
  </head>
  <body data-with-sidebar={withSidebar ? "true" : "false"}>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader />
    <div class="docs-shell" data-with-sidebar={withSidebar ? "true" : "false"}>
      {
        withSidebar && (
          <div class="docs-sidebar-slot" transition:persist="docs-sidebar">
            <slot name="sidebar" />
          </div>
        )
      }
      <main class="docs-main" id="main">
        {
          withSidebar && (
            <MobileNav client:load>
              <DocsSidebarNav />
            </MobileNav>
          )
        }
        <slot />
      </main>
      {
        withSidebar && (
          <div class="docs-toc-slot">
            <TableOfContents />
          </div>
        )
      }
    </div>
    <SiteFooter />
  </body>
</html>
