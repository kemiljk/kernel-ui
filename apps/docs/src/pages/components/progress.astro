---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import UsageAccordion from "../../components/UsageAccordion.astro";
import ProgressDemo from "../../components/demos/ProgressDemo";
import ProgressPlayground from "../../components/demos/ProgressPlayground";

const reactSnippet = `import { Progress } from "@kernelui/react";

<Progress value={60} label="Uploading" />`;
---

<BaseLayout title="Progress" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Progress</h1>
    <p>
      A real <code>&lt;progress&gt;</code>. It reports its own value to
      assistive tech without any <code>role="progressbar"</code>/
      <code>aria-valuenow</code> bookkeeping, and becomes an indeterminate
      spinner for free when you omit <code>value</code>.
    </p>

    <div class="docs-example" style="flex-direction: column; align-items: stretch;">
      <ProgressDemo client:load />
    </div>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the component — and the code — update live.</p>
    <ProgressPlayground client:load />

    <UsageAccordion code={reactSnippet} lang="tsx" />

    <h2>Props</h2>
    <table class="docs-table">
      <thead><tr><th>Prop</th><th>Type</th><th>Default</th></tr></thead>
      <tbody>
        <tr><td><code>value</code></td><td>number</td><td>—</td></tr>
        <tr><td><code>max</code></td><td>number</td><td>100</td></tr>
        <tr><td><code>label</code></td><td>string</td><td>—</td></tr>
      </tbody>
    </table>

    <p>
      Styling the fill has no standardised, non-vendor-prefixed API yet.
      <code>::-webkit-progress-value</code> and
      <code>::-moz-progress-bar</code> are the correct, current way to do
      it, not a legacy fallback.
    </p>
  </div>
</BaseLayout>
