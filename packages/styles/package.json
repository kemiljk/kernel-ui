{
  "name": "@kernelui-lib/styles",
  "version": "1.0.0",
  "description": "Kernel design tokens: CSS custom properties, baseline reset, and an optional Tailwind v4 bridge.",
  "license": "MIT",
  "author": "Karl Koch",
  "repository": {
    "type": "git",
