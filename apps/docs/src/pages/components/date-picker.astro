---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import UsageAccordion from "../../components/UsageAccordion.astro";
import DatePickerDemo from "../../components/demos/DatePickerDemo";

const usageSnippet = `import { useState } from "react";
import { DatePicker } from "@kernelui/react";

function BookingDate() {
  const [date, setDate] = useState<Date>();

  return <DatePicker value={date} onValueChange={setDate} minDate={new Date()} />;
}`;
---

<BaseLayout title="Date Picker" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Date Picker</h1>
    <p>
      A calendar month is a genuine grid, rows of weeks, columns of days
      of the week, so it's a real <code>&lt;table&gt;</code>, not a{" "}
      <code>&lt;div&gt;</code> grid pretending to be one. Each day is a
      real <code>&lt;button&gt;</code>; the selected one gets{" "}
      <code>aria-selected="true"</code>.
    </p>

    <div class="docs-example" style="flex-direction: column; align-items: stretch;">
      <DatePickerDemo client:load />
    </div>

    <UsageAccordion code={usageSnippet} lang="tsx" />

    <h2>Props</h2>
    <table class="docs-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th></tr>
      </thead>
      <tbody>
        <tr><td><code>value</code></td><td>Date</td><td>—</td></tr>
        <tr><td><code>defaultValue</code></td><td>Date</td><td>—</td></tr>
        <tr><td><code>onValueChange</code></td><td>(date: Date) =&gt; void</td><td>—</td></tr>
        <tr><td><code>minDate</code></td><td>Date</td><td>—</td></tr>
        <tr><td><code>maxDate</code></td><td>Date</td><td>—</td></tr>
      </tbody>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>Previous/next month controls are real <code>&lt;button&gt;</code>s with <code>aria-label</code>s ("Previous month", "Next month"), since their icons carry no accessible name on their own.</li>
      <li>The selected day gets <code>aria-selected="true"</code>; today's date gets a distinct dot indicator rather than being conflated with the selected state.</li>
      <li>Days outside <code>minDate</code>/<code>maxDate</code> are real <code>disabled</code> buttons, not just dimmed text.</li>
      <li>Days outside the displayed month render as non-interactive dimmed text, they aren't selectable without first navigating to that month.</li>
      <li>Arrow Left/Right/Up/Down, Home, and End move focus between the day buttons currently rendered in the grid; Home/End jump to the start/end of the focused day's week. Crossing into the next or previous month still requires the month navigation buttons, arrow keys don't auto-page the calendar.</li>
    </ul>
  </div>
</BaseLayout>
