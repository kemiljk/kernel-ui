---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import SwitchDemo from "../../components/demos/SwitchDemo";
import SwitchPlayground from "../../components/demos/SwitchPlayground";

---

<BaseLayout title="Switch" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Switch</h1>
    <p>
      There's no native switch element yet, so this follows the WAI-ARIA
      switch pattern: a real <code>&lt;button role="switch"&gt;</code>, which
      gets click, Space/Enter, and focus for free, with{" "}
      <code>aria-checked</code> telling assistive tech it's a two-state
      toggle rather than a regular button.
    </p>

    <div class="docs-example">
      <SwitchDemo client:load />
    </div>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the component — and the code — update live.</p>
    <SwitchPlayground client:load />

    
    <h2>Props</h2>
    <div class="docs-table-scroll"><table class="docs-table">
      <caption>Props for Switch.</caption>
      <thead>
        <tr><th scope="col">Prop</th><th scope="col">Type</th><th scope="col">Default</th></tr>
      </thead>
      <tbody>
        <tr><td><code>checked</code> / <code>defaultChecked</code></td><td>boolean</td><td>false</td></tr>
        <tr><td><code>onCheckedChange</code></td><td>(checked: boolean) =&gt; void</td><td>—</td></tr>
      </tbody>
    </table></div>

    <h2>Accessibility</h2>
    <p>
      Wrapping it with label text works because <code>&lt;button&gt;</code>{" "}
      is a labelable element, exactly like <code>&lt;input&gt;</code>, so
      clicking the text toggles the switch without any extra click handler.
    </p>
  </div>
</BaseLayout>
