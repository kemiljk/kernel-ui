---
/**
 * A canvas phyllotaxis animation, adapted from a reference shader the
 * project owner supplied (radiant-shaders.com's phyllotaxis demo).
 * Kept as a plain `<script>` in an Astro component rather than a React
 * island: it's a self-contained imperative canvas loop with no props
 * or reactive state, so hydrating a whole framework for it would be
 * pure overhead.
 *
 * Differences from the reference (which was a full-viewport, fixed
 * dark-background demo page):
 * - Sized to its own container instead of the viewport.
 * - Colours are resolved from --kernel-accent-6/-9/-11 at runtime via
 *   a hidden probe element, kept and manipulated as oklch() strings
 *   (not converted to rgb — this browser's computed style already
 *   returns colour as oklch(), and Canvas 2D's fillStyle accepts
 *   oklch() with a CSS Color 4 `/ alpha` suffix directly), so alpha
 *   fading needs no colour-space conversion at all. Re-resolved on
 *   every accent/theme change so it reshades live like every other
 *   visual on this page.
 * - Fully transparent canvas, no background fill/vignette of any
 *   kind: a rectangular fillRect is a hard box no matter what colour
 *   it fades to, which is exactly the "boxed-in" look this is meant
 *   to avoid. Only the dots and their soft per-dot glow are drawn.
 * - `prefers-reduced-motion` renders one fully-grown, static frame
 *   instead of the continuous growth/pulse/rotation loop.
 */
---

<div class="hero-phyllotaxis">
  <canvas aria-hidden="true"></canvas>
</div>

<script>
  const GOLDEN_ANGLE = 137.508 * (Math.PI / 180);
  const MAX_POINTS = 480;

  interface Oklch {
    l: number;
    c: number;
    h: number;
  }

  const FALLBACK: Oklch = { l: 0.7, c: 0.15, h: 70 };

  function resolveVar(name: string): Oklch {
    const probe = document.createElement("span");
    probe.style.color = `var(${name})`;
    document.body.appendChild(probe);
    const resolved = getComputedStyle(probe).color;
    probe.remove();
    // This engine's computed style returns oklch() directly for an
    // oklch()-defined custom property (rather than converting to
    // rgb()) — parse it as such; fall back to a plain amber tone for
    // any engine that resolves to something else instead.
    const match = resolved.match(/oklch\(\s*([\d.]+)%?\s+([\d.]+)\s+([\d.]+)/);
    if (!match) return FALLBACK;
    return { l: Number(match[1]), c: Number(match[2]), h: Number(match[3]) };
  }

  function lerpOklch(a: Oklch, b: Oklch, t: number): Oklch {
    return {
      l: a.l + (b.l - a.l) * t,
      c: a.c + (b.c - a.c) * t,
      h: a.h + (b.h - a.h) * t,
    };
  }

  function oklchStyle(color: Oklch, alpha: number) {
    return `oklch(${color.l} ${color.c} ${color.h} / ${alpha})`;
  }

  function initPhyllotaxis(root: HTMLElement) {
    const canvas = root.querySelector("canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Darkest to palest step of the active accent ramp — cycling
    // between them along the spiral gives each arm gentle variation
    // rather than one flat colour, without ever leaving the theme.
    let palette: Oklch[] = [
      resolveVar("--kernel-accent-11"),
      resolveVar("--kernel-accent-9"),
      resolveVar("--kernel-accent-6"),
    ];

    function refreshPalette() {
      palette = [
        resolveVar("--kernel-accent-11"),
        resolveVar("--kernel-accent-9"),
        resolveVar("--kernel-accent-6"),
      ];
    }

    function getColor(index: number): Oklch {
      const cycle = (index * 0.05) % 3;
      const segment = Math.floor(cycle);
      const t = cycle - segment;
      return lerpOklch(palette[segment % 3], palette[(segment + 1) % 3], t);
    }

    let width = 0;
    let height = 0;
    let cx = 0;
    let cy = 0;
    let dpr = 1;
    let spread = 1;
    let lastTime = 0;
    let lastRotation = 0;
    let dragRotation = 0;
    const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    // How much bigger the canvas itself is than the box that lays it
    // out. A <canvas> can't visually overflow its box the way a DOM
    // element can — content past its own width/height is simply never
    // painted — so the only way for the pattern to read as extending
    // past its nominal "frame" instead of being clipped by it is for
    // the canvas to already be larger than that frame, centred over
    // it. spread (the spiral's actual scale) is still derived from
    // the frame's own size, not the enlarged canvas, so the pattern's
    // density doesn't change — it just gets room to breathe past the
    // edge instead of a hard cutoff.
    const OVERFLOW = 1.7;

    interface Point {
      n: number;
      baseAngle: number;
      baseRadius: number;
      color: Oklch;
      birth: number;
    }

    // Declared before resize()/repaint() below, both of which read
    // `points` — resize() is called synchronously as soon as it's
    // defined (a few lines down), which would otherwise try to read
    // `points` before this declaration had run.
    let points: Point[] = [];
    let pointIndex = 0;
    let globalTime = 0;

    function resize() {
      const rect = root.getBoundingClientRect();
      dpr = window.devicePixelRatio || 1;
      width = rect.width * OVERFLOW;
      height = rect.height * OVERFLOW;
      canvas!.width = width * dpr;
      canvas!.height = height * dpr;
      canvas!.style.width = `${width}px`;
      canvas!.style.height = `${height}px`;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      cx = width / 2;
      cy = height / 2;
      spread = Math.min(rect.width, rect.height) * 0.032;
      // Setting canvas.width/height — even to a value it already had —
      // always clears the drawing buffer, per spec. ResizeObserver
      // guarantees one callback right after observe() starts even when
      // nothing has actually resized yet, which was wiping out the
      // very first paint and leaving an empty canvas until the next
      // requestAnimationFrame tick happened to land. Repainting
      // whatever's already in `points` here closes that gap.
      repaint();
    }

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(root);
    resize();

    function addPoint() {
      const n = pointIndex;
      points.push({
        n,
        baseAngle: n * GOLDEN_ANGLE,
        baseRadius: spread * Math.sqrt(n),
        color: getColor(n),
        birth: globalTime,
      });
      pointIndex++;
    }

    function drawGlow(time: number) {
      // The brightest step of the ramp, not the darkest: a "glow"
      // drawn in the ramp's darkest tone just reads as a smudge.
      const pulse = 0.35 + 0.12 * Math.sin(time * 1.2);
      const radius = Math.min(width, height) * 0.2;
      const gradient = ctx!.createRadialGradient(cx, cy, 0, cx, cy, radius);
      gradient.addColorStop(0, oklchStyle(palette[1], pulse * 0.28));
      gradient.addColorStop(1, oklchStyle(palette[1], 0));
      ctx!.fillStyle = gradient;
      ctx!.beginPath();
      ctx!.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx!.fill();
    }

    function drawConnections(rotation: number) {
      const len = points.length;
      if (len < 2) return;
      ctx!.lineWidth = 0.5;
      const strides = [1, 8, 13];
      const maxDist = Math.min(width, height) * 0.14;

      for (let s = 0; s < strides.length; s++) {
        const stride = strides[s];
        const baseAlpha = s === 0 ? 0.08 : s === 1 ? 0.05 : 0.03;
        for (let i = 0; i < len - stride; i++) {
          const p1 = points[i];
          const p2 = points[i + stride];
          const fadeIn1 = Math.min(1, (globalTime - p1.birth) / 60);
          const fadeIn2 = Math.min(1, (globalTime - p2.birth) / 60);
          if (fadeIn1 < 0.1 || fadeIn2 < 0.1) continue;

          const a1 = p1.baseAngle + rotation;
          const a2 = p2.baseAngle + rotation;
          const x1 = cx + Math.cos(a1) * p1.baseRadius;
          const y1 = cy + Math.sin(a1) * p1.baseRadius;
          const x2 = cx + Math.cos(a2) * p2.baseRadius;
          const y2 = cy + Math.sin(a2) * p2.baseRadius;
          const dist = Math.hypot(x2 - x1, y2 - y1);
          if (dist > maxDist) continue;

          const alpha = baseAlpha * Math.max(0, 1 - dist / maxDist) * fadeIn1 * fadeIn2;
          if (alpha < 0.004) continue;
          ctx!.strokeStyle = oklchStyle(p1.color, alpha);
          ctx!.beginPath();
          ctx!.moveTo(x1, y1);
          ctx!.lineTo(x2, y2);
          ctx!.stroke();
        }
      }
    }

    // Repaints whatever's currently in `points` without changing which
    // points exist — used after a resize (which clears the canvas even
    // when nothing actually changed size) and after a theme swap,
    // neither of which should regenerate or regrow the pattern.
    function repaint() {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);
      if (reducedMotionQuery.matches) {
        drawGlow(0);
        drawConnections(dragRotation);
        drawPoints(0, dragRotation, false);
      } else {
        drawGlow(lastTime);
        drawConnections(lastRotation);
        drawPoints(lastTime, lastRotation, true);
      }
    }

    function drawPoints(time: number, rotation: number, animate: boolean) {
      const len = points.length;
      for (let i = 0; i < len; i++) {
        const p = points[i];
        const age = globalTime - p.birth;
        const fadeIn = animate ? Math.min(1, age / 40) : 1;
        let fadeOut = 1;
        if (animate && i < len * 0.08) fadeOut = i / (len * 0.08);

        const pulse = animate ? 1 + 0.12 * Math.sin(time * 2 + p.n * 0.1) : 1;
        const baseSize = 1.1 + Math.min(2.2, age * 0.02);
        const size = baseSize * pulse;
        const r = p.baseRadius * pulse;
        const angle = p.baseAngle + rotation;
        const x = cx + Math.cos(angle) * r;
        const y = cy + Math.sin(angle) * r;
        if (x < -10 || x > width + 10 || y < -10 || y > height + 10) continue;

        const alpha = fadeIn * fadeOut * (0.6 + 0.4 * pulse);

        ctx!.fillStyle = oklchStyle(p.color, alpha);
        ctx!.beginPath();
        ctx!.arc(x, y, size, 0, Math.PI * 2);
        ctx!.fill();

        if (alpha > 0.4) {
          ctx!.fillStyle = `rgba(255, 250, 240, ${alpha * 0.5})`;
          ctx!.beginPath();
          ctx!.arc(x, y, size * 0.4, 0, Math.PI * 2);
          ctx!.fill();
        }
      }
    }

    // Drag to tilt-rotate the spiral a little further — a light,
    // discrete, user-initiated gesture, not an ambient effect, so it
    // stays enabled even under prefers-reduced-motion.
    let dragging = false;
    let lastX = 0;

    canvas.addEventListener("pointerdown", (e) => {
      dragging = true;
      lastX = e.clientX;
    });
    canvas.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      dragRotation += (e.clientX - lastX) * 0.008;
      lastX = e.clientX;
    });
    window.addEventListener("pointerup", () => {
      dragging = false;
    });

    let rafId = 0;

    function renderStatic() {
      points = [];
      pointIndex = 0;
      for (let i = 0; i < MAX_POINTS; i++) addPoint();
      repaint();
    }

    function renderFrame(time: number, rotation: number) {
      ctx!.clearRect(0, 0, width, height);
      drawGlow(time);
      drawConnections(rotation);
      drawPoints(time, rotation, true);
    }

    function loop(timestamp: number) {
      lastTime = timestamp / 1000;
      lastRotation = lastTime * 0.015 + dragRotation;
      globalTime++;
      // Stops for good once the full pattern (MAX_POINTS) exists —
      // this used to keep incrementing pointIndex well past that
      // while shifting the oldest (innermost) points out to compensate,
      // which meant the spiral never actually settled: it kept
      // hollowing out from the centre and migrating outward as a
      // thinning ring until it drifted past the canvas's own drawable
      // bounds and got culled entirely. A phyllotaxis pattern that's
      // finished growing should just sit there, alive via the pulse
      // and rotation below, not keep cycling its membership forever.
      if (pointIndex < MAX_POINTS) addPoint();
      renderFrame(lastTime, lastRotation);
      rafId = requestAnimationFrame(loop);
    }

    function start() {
      cancelAnimationFrame(rafId);
      points = [];
      pointIndex = 0;
      globalTime = 0;
      if (reducedMotionQuery.matches) {
        renderStatic();
        return;
      }
      // Seed roughly half the pattern in fully-grown, rather than
      // growing the whole thing from nothing: a homepage hero needs
      // to read as complete on first paint, not several seconds in.
      // The rest keeps growing in on top of this via the loop above.
      const seedCount = Math.floor(MAX_POINTS * 0.5);
      for (let i = 0; i < seedCount; i++) {
        points.push({
          n: i,
          baseAngle: i * GOLDEN_ANGLE,
          baseRadius: spread * Math.sqrt(i),
          color: getColor(i),
          birth: -1000,
        });
      }
      pointIndex = seedCount;
      // Paint the seeded pattern immediately rather than waiting for
      // the first requestAnimationFrame callback, so there's no flash
      // of an empty hero before the loop gets scheduled.
      renderFrame(0, dragRotation);
      rafId = requestAnimationFrame(loop);
    }

    reducedMotionQuery.addEventListener("change", start);

    new MutationObserver(() => {
      refreshPalette();
      // Every existing dot's colour was baked in once at creation
      // (getColor(n) is only cheap to call per-point, not per-frame),
      // so a theme switch has to explicitly recolour them — refreshing
      // the palette alone only affects dots added after this point.
      for (const p of points) p.color = getColor(p.n);
      // repaint() redraws immediately rather than waiting for the next
      // requestAnimationFrame tick, so the switch reads as instant
      // instead of depending on the loop's own cadence.
      repaint();
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-kernel-accent", "data-theme"],
    });

    start();
  }

  document.querySelectorAll<HTMLElement>(".hero-phyllotaxis").forEach(initPhyllotaxis);
</script>
