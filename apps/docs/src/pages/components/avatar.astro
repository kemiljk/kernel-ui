---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import AvatarDemo from "../../components/demos/AvatarDemo";
import AvatarPlayground from "../../components/demos/AvatarPlayground";

---

<BaseLayout title="Avatar" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Avatar</h1>
    <p>
      A real <code>&lt;img&gt;</code> when there's a picture. Broken or
      missing images can't be detected in CSS alone, so the fallback swap
      to initials is the one deliberate piece of JavaScript here, an
      <code>onError</code> handler, everything else is native image
      handling.
    </p>

    <div class="docs-example">
      <AvatarDemo client:load />
    </div>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the component — and the code — update live.</p>
    <AvatarPlayground client:load />

    
    <h2>Props</h2>
    <div class="docs-table-scroll"><table class="docs-table">
      <caption>Props for Avatar.</caption>
      <thead><tr><th scope="col">Prop</th><th scope="col">Type</th><th scope="col">Default</th></tr></thead>
      <tbody>
        <tr><td><code>fallback</code></td><td>string (required)</td><td>—</td></tr>
        <tr><td><code>src</code></td><td>string</td><td>—</td></tr>
        <tr><td><code>alt</code></td><td>string</td><td>—</td></tr>
      </tbody>
    </table></div>
  </div>
</BaseLayout>
