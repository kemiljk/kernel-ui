{
  "name": "kernel-ui-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run --filter '@kernelui-lib/*' build",
    "dev": "bun run --cwd packages/react build && bun scripts/dev.mjs",
    "dev:react": "bun run --cwd packages/react dev",
    "docs:build": "bun run --cwd packages/react build && bun run --cwd apps/docs build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --cwd packages/react test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "smoke:consumer": "node scripts/smoke-test-consumer.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1"
  }
}
