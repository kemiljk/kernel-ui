---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import SeparatorDemo from "../../components/demos/SeparatorDemo";
import SeparatorPlayground from "../../components/demos/SeparatorPlayground";

---

<BaseLayout title="Separator" withSidebar>
  <DocsSidebar slot="sidebar" />
  <div class="docs-prose">
    <h1>Separator</h1>
    <p>
      A real <code>&lt;hr&gt;</code>. Browsers already expose it to
      assistive tech as <code>role="separator"</code>, a horizontal rule is
      exactly what a divider is. <code>orientation="vertical"</code> repaints
      it without changing what it means.
    </p>

    <div class="docs-example">
      <SeparatorDemo client:load />
    </div>

    <h2>Playground</h2>
    <p>Toggle every adjustable prop and watch the component — and the code — update live.</p>
    <SeparatorPlayground client:load />

    
    <h2>Props</h2>
    <div class="docs-table-scroll"><table class="docs-table">
      <caption>Props for Separator.</caption>
      <thead><tr><th scope="col">Prop</th><th scope="col">Type</th><th scope="col">Default</th></tr></thead>
      <tbody>
        <tr><td><code>orientation</code></td><td>"horizontal" | "vertical"</td><td>"horizontal"</td></tr>
      </tbody>
    </table></div>
  </div>
</BaseLayout>
